{%- macro menu_link(item) %}
  {%- set itemURL = item.path %}
  <li class="menu-item menu-item-{{ item.name | lower | replace(' ', '-') }}">
    {%- set menuIcon = '<i class="' + item.icon + ' fa-fw"></i>' if theme.menu_settings.icons and item.icon else '' %}
    {%- set menuText = __('menu.' + item.name) | replace('menu.', '') %}
    {{- next_url(itemURL, menuIcon + menuText, {rel: 'section'}) -}}
  </li>
{%- endmacro %}

{%- macro search_item() %}
  <li class="menu-item menu-item-search">
    <a role="button" class="popup-trigger">
      {%- if theme.menu_settings.icons %}<i class="fa fa-search fa-fw"></i>{% endif %}搜索
    </a>
  </li>
{%- endmacro %}

{%- if theme.menu or theme.algolia_search.enable or theme.local_search.enable %}
<nav class="site-nav">
  <ul class="main-menu menu">
    {%- for node in theme.main_menu %}
      {{- menu_link(node) | trim }}
      {%- if node.name == '新人' and (theme.algolia_search.enable or theme.local_search.enable) %}
      {{- search_item() | trim }}
      {%- endif %}
    {%- endfor %}
  </ul>
</nav>
{%- endif %}
