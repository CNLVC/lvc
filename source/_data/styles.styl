// Hide images on homepage, show only in article detail page
.posts-expand .post-body img {
  display: none;
}

.posts-expand .post-body a img {
  display: none;
}

// ==========================================
// Dark Mode
// ==========================================

.darkmode {
  background-color: #1c1c1e !important;
  color: #e5e5e7 !important;
}

// Dark mode header/navigation - #333333
.darkmode .header,
.darkmode #header,
.darkmode header.header {
  background-color: #333333 !important;
  border-bottom-color: #444 !important;
}

.darkmode .site-title,
.darkmode .site-title a,
.darkmode .site-subtitle {
  color: #ffffff !important;
}

// Dark mode sidebar - #333333
.darkmode .sidebar,
.darkmode #sidebar,
.darkmode aside.sidebar {
  background-color: #333333 !important;
  box-shadow: none !important;
}

.darkmode .sidebar-inner,
.darkmode .sidebar-panel {
  background-color: #333333 !important;
}

.darkmode .footer {
  background-color: #333333 !important;
  border-top-color: #444 !important;
  color: #e5e5e7 !important;
}

.darkmode a {
  color: #6eb5ff !important;
}

.darkmode a:hover {
  color: #9ecfff !important;
}

.darkmode .post,
.darkmode .post-block {
  background-color: #2c2c2e !important;
  border-color: #38383a !important;
  box-shadow: none !important;
}

.darkmode .post-title,
.darkmode .post-title a,
.darkmode .post-meta,
.darkmode .post-content,
.darkmode .post-body,
.darkmode .post-entry {
  color: #e5e5e7 !important;
}

.darkmode .post-link {
  color: #6eb5ff !important;
}

.darkmode .menu-item a,
.darkmode .menu .menu-item a,
.darkmode .nav-item a {
  color: #e5e5e7 !important;
}

.darkmode .menu-item a:hover,
.darkmode .nav-item a:hover {
  color: #6eb5ff !important;
}

.darkmode .back-to-top {
  background-color: #333333 !important;
  color: #e5e5e7 !important;
}

// Dark mode toggle button
.darkmode .darkmode-toggle-btn {
  background: #4a4a4a !important;
  color: #ffffff !important;
  border: 1px solid #666 !important;
  box-shadow: none !important;
}

.darkmode .darkmode-toggle-btn:hover {
  background: #5a5a5a !important;
}

.darkmode code,
.darkmode pre {
  background-color: #2c2c2e !important;
  color: #e5e5e7 !important;
}

.darkmode blockquote {
  border-left-color: #6eb5ff !important;
  background-color: #2c2c2e !important;
  color: #e5e5e7 !important;
}

.darkmode .tags a,
.darkmode .categories a,
.darkmode .tag-list a,
.darkmode .category-list a {
  background-color: #3a3a3c !important;
  color: #e5e5e7 !important;
  border-color: #555 !important;
}

.darkmode .pagination .page-number,
.darkmode .pagination a {
  background-color: #3a3a3c !important;
  color: #e5e5e7 !important;
  border-color: #555 !important;
}

.darkmode .btn {
  background-color: #3a3a3c !important;
  color: #e5e5e7 !important;
  border-color: #555 !important;
}

.darkmode input,
.darkmode textarea,
.darkmode select {
  background-color: #2c2c2e !important;
  color: #e5e5e7 !important;
  border-color: #555 !important;
}

.darkmode .site-state-item,
.darkmode .site-state-item a {
  color: #e5e5e7 !important;
}

.darkmode .author-info {
  background-color: #333333 !important;
  color: #e5e5e7 !important;
}

// Dark mode "阅读全文" button and pagination - #1c1c1e
.darkmode .post-button a,
.darkmode .posts-expand .post-button .btn,
.darkmode .read-more-btn {
  background-color: #1c1c1e !important;
  color: #e5e5e7 !important;
  border-color: #444 !important;
}

.darkmode .pagination,
.darkmode .pagination-wrap,
.darkmode .pagination .prev,
.darkmode .pagination .next,
.darkmode .pagination .page-number {
  background-color: #1c1c1e !important;
  border-color: #38383a !important;
}

.darkmode .pagination .page-number {
  background-color: #1c1c1e !important;
  color: #e5e5e7 !important;
  border: 1px solid #38383a !important;
}

// ==========================================
// Light Mode
// ==========================================

// Homepage background - white
body:not(.darkmode) {
  background-color: #ffffff !important;
}

// Light mode header/navigation bar - #f5f5f5 background, black text
body:not(.darkmode) .header,
body:not(.darkmode) #header,
body:not(.darkmode) header.header,
body:not(.darkmode) .header-inner,
body:not(.darkmode) .site-head {
  background-color: #f5f5f5 !important;
  border-bottom-color: #aaa !important;
}

body:not(.darkmode) .site-title a,
body:not(.darkmode) .brand {
  color: #000000 !important;
}

body:not(.darkmode) .site-subtitle {
  color: #000000 !important;
}

body:not(.darkmode) .menu-item a {
  color: #000000 !important;
}

body:not(.darkmode) .menu-item a:hover,
body:not(.darkmode) .menu-item a.menu-item-active {
  color: #000000 !important;
  background-color: #CCCCCC !important;
}

// Light mode sidebar - #f5f5f5 background, text black
body:not(.darkmode) .sidebar,
body:not(.darkmode) #sidebar,
body:not(.darkmode) aside.sidebar {
  background-color: #f5f5f5 !important;
  box-shadow: none !important;
}

body:not(.darkmode) .sidebar-inner,
body:not(.darkmode) .sidebar-panel {
  background-color: #f5f5f5 !important;
}

body:not(.darkmode) .site-author-image {
  border: none !important;
  box-shadow: none !important;
}

body:not(.darkmode) .site-author-name,
body:not(.darkmode) .site-description,
body:not(.darkmode) .site-state-item,
body:not(.darkmode) .site-state-item a,
body:not(.darkmode) .site-state-item-count,
body:not(.darkmode) .site-state-item-name,
body:not(.darkmode) .links-of-blogroll-title,
body:not(.darkmode) .links-of-blogroll-item a,
body:not(.darkmode) .sidebar-nav li,
body:not(.darkmode) .sidebar-nav a {
  color: #000000 !important;
}

// Social links in sidebar
body:not(.darkmode) .sidebar .social-links,
body:not(.darkmode) .social-links-item a,
body:not(.darkmode) .links-of-blogroll a {
  color: #000000 !important;
}

// Light mode footer
body:not(.darkmode) .footer {
  background-color: #f5f5f5 !important;
  border-top-color: #aaa !important;
  color: #000000 !important;
}

// Light mode homepage posts - WHITE background, black text
body:not(.darkmode) .main-inner {
  background-color: #ffffff !important;
}

body:not(.darkmode) .column {
  background-color: #f5f5f5 !important;
}

body:not(.darkmode) .posts-expand,
body:not(.darkmode) .posts-expand .post {
  background-color: #ffffff !important;
  border-color: #ddd !important;
  box-shadow: none !important;
}

body:not(.darkmode) .post-title,
body:not(.darkmode) .post-title a,
body:not(.darkmode) .post-meta,
body:not(.darkmode) .post-content,
body:not(.darkmode) .post-body,
body:not(.darkmode) .post-entry,
body:not(.darkmode) .post-description {
  color: #000000 !important;
}

body:not(.darkmode) .post-link {
  color: #333333 !important;
}

// Light mode "阅读全文" button
body:not(.darkmode) .post-button a,
body:not(.darkmode) .posts-expand .post-button .btn,
body:not(.darkmode) .read-more-btn {
  background-color: #ffffff !important;
  color: #000000 !important;
  border: none !important;
}

// Light mode toggle button
body:not(.darkmode) .darkmode-toggle-btn {
  background: #e0e0e0 !important;
  color: #333333 !important;
  border: 1px solid #bbb !important;
  box-shadow: none !important;
}

body:not(.darkmode) .darkmode-toggle-btn:hover {
  background: #d0d0d0 !important;
}

// Light mode pagination
body:not(.darkmode) .pagination .page-number {
  background-color: #ffffff !important;
  color: #000000 !important;
  border: none !important;
}

body:not(.darkmode) .pagination a {
  background-color: #ffffff !important;
  color: #000000 !important;
  border: none !important;
}
